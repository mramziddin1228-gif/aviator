{
  "expo": {
    "name": "Aviator Winn Mobile",
    "slug": "aviator-winn-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "aviatorwinn",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/start/logo_patch.png",
      "resizeMode": "contain",
      "backgroundColor": "#0310D7"
    },
    "ios": {
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": true
      },
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
