# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
/data/telegram-admins.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# excluded sensitive Telegram route handlers
/src/app/api/telegram/credentials/route.ts
/src/app/api/telegram/payment/route.ts
/src/app/api/telegram/registration/route.ts

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
